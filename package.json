{
  "name": "gremllm",
  "productName": "Gremllm",
  "version": "0.7.0",
  "description": "An Experimental IDE (Idea Development Environment)",
  "license": "MIT",
  "author": "Quantisan, LLC",
  "main": "target/main.js",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "npm run clean && shadow-cljs compile main renderer",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "repl": "shadow-cljs cljs-repl renderer",
    "clean": "rm -rf .shadow-cljs target resources/public/compiled-js",
    "test": "shadow-cljs compile test",
    "test:ci": "shadow-cljs compile test --config-merge '{:autorun false}' && node target/test.js",
    "test:watch": "shadow-cljs watch test",
    "test:all": "shadow-cljs compile test-all",
    "test:integration": "shadow-cljs compile test-integration",
    "release:patch": "npm version patch -m \"chore(release): %s\" && git push --follow-tags",
    "release:minor": "npm version minor -m \"chore(release): %s\" && git push --follow-tags"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/publisher-github": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "concurrently": "^9.2.0",
    "electron": "^41.2.1",
    "electron-reload": "^2.0.0-alpha.1",
    "shadow-cljs": "^3.4.4",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.29.2",
    "@agentclientprotocol/sdk": "^0.19.0",
    "@dotenvx/dotenvx": "^1.61.0",
    "markdown-it": "14.1.1",
    "markdown-it-block-image": "0.0.3",
    "markdown-it-footnote": "4.0.0",
    "markdown-it-texmath": "1.0.0",
    "markdown-it-toc-done-right": "4.2.0",
    "punycode": "2.3.1"
  }
}
